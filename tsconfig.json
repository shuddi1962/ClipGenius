{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@clipgenius/shared": ["packages/shared/index.ts"],
      "@clipgenius/shared/*": ["packages/shared/*"],
      "@clipgenius/ui": ["packages/ui/index.ts"],
      "@clipgenius/ui/*": ["packages/ui/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
