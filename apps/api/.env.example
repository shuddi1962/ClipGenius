# InsForge
INSFORGE_URL=https://api.insforge.dev
INSFORGE_API_KEY=your_insforge_api_key_here
INSFORGE_DB_NAME=nexus

# Server
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# Auth
JWT_SECRET=your_jwt_secret_here_32_chars_min
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_32_chars_min
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (for API keys vault)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ENCRYPTION_IV_LENGTH=16

# Redis
REDIS_URL=redis://localhost:6379

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Email (platform transactional — before admin configures)
SYSTEM_SMTP_HOST=smtp.gmail.com
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_USER=your_email@gmail.com
SYSTEM_SMTP_PASS=your_app_password
SYSTEM_FROM_EMAIL=noreply@nexus.app