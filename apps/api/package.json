    "@fastify/rate-limit": "^9.1.0",
    "@mozilla/readability": "^0.5.0",
    "axios": "^1.6.8",
    "bullmq": "^5.4.2",
    "canvas": "^2.11.2",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "got": "^14.2.1",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
