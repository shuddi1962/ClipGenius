{
  "name": "clipgenius",
  "version": "1.0.0",
  "description": "NEXUS — Ultimate Production-Ready All-In-One SaaS Platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "start": "npm run start:backend",
    "start:frontend": "cd apps/web && npm run start",
    "start:backend": "cd backend && npm run start",
    "start:docker": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "deploy:vercel": "vercel --prod",
    "seed:demo": "cd backend && npm run seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "concurrently": "^8.2.2",
    "typescript": "^5"
  },
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
